# Copie ce fichier en .env (non versionné) et adapte les valeurs.

# --- Accès interne (obligatoire en prod) ---
APP_USER=aem
APP_PASSWORD=change-moi-vraiment

# --- Réseau ---
PORT=3000
HOST=0.0.0.0

# --- ffmpeg (laisser vide si ffmpeg est dans le PATH) ---
# FFMPEG_BIN=/usr/bin/ffmpeg

# --- Limites d'upload ---
MAX_FILES=40
MAX_FILE_MB=25

# --- Rendus simultanés (1 recommandé sur un petit VPS) ---
RENDER_CONCURRENCY=1

# --- IA image->vidéo (optionnel) ---
# REPLICATE_API_TOKEN=r8_xxx
# REPLICATE_MODEL=wan-video/wan-2.2-i2v-fast
# REPLICATE_IMAGE_FIELD=image
