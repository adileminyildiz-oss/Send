# Reverse proxy Nginx pour send.aemconseil.eu -> app Node (port 3000).
# À placer dans /etc/nginx/sites-available/send.aemconseil.eu puis :
#   sudo ln -s /etc/nginx/sites-available/send.aemconseil.eu /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#   sudo certbot --nginx -d send.aemconseil.eu   # certificat HTTPS gratuit

server {
    listen 80;
    server_name send.aemconseil.eu;

    # Taille max des uploads (photos) — doit être >= MAX_FILES * MAX_FILE_MB.
    client_max_body_size 1024M;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Le rendu peut être long : on augmente les timeouts.
        proxy_read_timeout 900s;
        proxy_send_timeout 900s;
    }
}
